## 建置產出 / 不上 commit 的目錄 ##############################################
/Build/
/Build_orig/
[Bb]in/
[Oo]bj/
[Oo]ut/
artifacts/

## 私人 / 暫存目錄 ###########################################################
/private/
/temp/
/tmp/
*.tmp

## 執行期產物 ################################################################
*.log
crash.log

################################################################################
# Visual Studio / C# / .NET
################################################################################

## Visual Studio 使用者與快取 #################################################
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates
*.userprefs
*.rsuser
*.vsidx
*.lock.json

## 建置組態目錄（VS 慣例） ###################################################
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Ll]og/
[Ll]ogs/

## NuGet ######################################################################
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets
project.lock.json
project.fragment.lock.json

## 測試結果 ###################################################################
[Tt]est[Rr]esult*/
